# Database
DATABASE_URL=postgresql+psycopg://postgres:your-password@localhost:5432/CineVerse

# JWT
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# AI service
AI_BASE_URL=http://localhost:8001

# Email verification
EMAIL_VERIFICATION_EXPIRE_MINUTES=5
EMAIL_VERIFICATION_RESEND_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# SMTP (for Gmail, use an app password rather than your account password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@example.com

# Password reset
FRONTEND_BASE_URL=http://localhost:5173
PASSWORD_RESET_EXPIRE_MINUTES=30

# TMDB (TMDB_ACCESS_TOKEN can be used instead of TMDB_API_KEY by import scripts)
TMDB_API_KEY=your-tmdb-api-key
TMDB_ACCESS_TOKEN=your-tmdb-read-access-token
