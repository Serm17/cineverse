# JWT token signing secret. Replace with a long random value in local .env.
SECRET_KEY=change-me-to-a-long-random-secret

# JWT signing algorithm.
ALGORITHM=HS256

# Token expiration settings.
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# Internal service URLs.
BE2_BASE_URL=http://127.0.0.1:8001
AI_BASE_URL=http://210.109.15.251

# External API keys.
TMDB_API_KEY=your-tmdb-api-key

# Used by scripts/backfill_movie_keywords.py.
DATABASE_URL=postgresql://postgres:1234@localhost:5432/CineVerse
